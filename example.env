# SkyCast API Keys & Configurations Template
# Rename this file to '.env' and fill in your actual credentials.

# 1. 기상청 단기예보 Open API Key (공공데이터포털)
WEATHER_API_KEY="your_kma_api_key_here"

# 2. Google OAuth 2.0 Client ID (Google Cloud Console)
GOOGLE_CLIENT_ID="your_google_client_id_here.apps.googleusercontent.com"

# 3. Google OAuth 2.0 Client Secret (Google Cloud Console)
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
